# Entorno de aplicacion
ENVIRONMENT=local
LOG_LEVEL=INFO

# API
API_HOST=127.0.0.1
API_PORT=8000

# Base de datos
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=restauria_dev
POSTGRES_USER=restauria_app
POSTGRES_PASSWORD=cambiar_esta_password
DATABASE_URL=postgresql+psycopg://restauria_app:cambiar_esta_password@127.0.0.1:5432/restauria_dev

# MVP
DEFAULT_TIMEZONE=UTC
ENABLE_POSTGRES=false

